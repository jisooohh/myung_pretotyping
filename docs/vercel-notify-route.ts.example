import { NextRequest, NextResponse } from 'next/server';
import { Resend } from 'resend';

export async function POST(req: NextRequest) {
  const resend = new Resend(process.env.RESEND_API_KEY || 're_placeholder');
  try {
    const body = await req.json();
    const { name, birthDate, birthTime, gender, region } = body;

    const html = `
      <div style="font-family: sans-serif; max-width: 560px; margin: 0 auto; padding: 24px; background: #15130F; color: #F4F1E9; border-radius: 12px;">
        <div style="font-size: 24px; font-weight: 800; color: #F4831B; margin-bottom: 4px;">myung.ai</div>
        <div style="font-size: 13px; color: #9B9186; margin-bottom: 24px;">새 사용자 온보딩 완료</div>
        <table style="width: 100%; border-collapse: collapse;">
          <tr>
            <td style="padding: 10px 0; border-bottom: 1px solid #2A2520; color: #9B9186; font-size: 13px; width: 90px;">이름</td>
            <td style="padding: 10px 0; border-bottom: 1px solid #2A2520; font-size: 14px; font-weight: 600;">${name || '—'}</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; border-bottom: 1px solid #2A2520; color: #9B9186; font-size: 13px;">생년월일</td>
            <td style="padding: 10px 0; border-bottom: 1px solid #2A2520; font-size: 14px; font-weight: 600;">${birthDate || '—'}</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; border-bottom: 1px solid #2A2520; color: #9B9186; font-size: 13px;">출생 시간</td>
            <td style="padding: 10px 0; border-bottom: 1px solid #2A2520; font-size: 14px; font-weight: 600;">${birthTime || '미입력'}</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; border-bottom: 1px solid #2A2520; color: #9B9186; font-size: 13px;">성별</td>
            <td style="padding: 10px 0; border-bottom: 1px solid #2A2520; font-size: 14px; font-weight: 600;">${gender === 'male' ? '남성' : gender === 'female' ? '여성' : '미입력'}</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: #9B9186; font-size: 13px;">지역</td>
            <td style="padding: 10px 0; font-size: 14px; font-weight: 600;">${region || '미입력'}</td>
          </tr>
        </table>
        <div style="margin-top: 24px; font-size: 11px; color: #5C534A;">
          ${new Date().toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' })} KST
        </div>
      </div>
    `;

    await resend.emails.send({
      from: 'myung.ai <onboarding@resend.dev>',
      to: 'voidmule.xx@gmail.com',
      subject: `[myung.ai] ${name || '새 사용자'} 님이 클론 생성을 시작했어요`,
      html,
    });

    return NextResponse.json({ ok: true });
  } catch (error) {
    console.error('[notify] error:', error);
    return NextResponse.json({ ok: false, error: String(error) }, { status: 500 });
  }
}
